# Copy this file to .env and fill in your local values. Never commit .env.
# Every variable below is optional — the platform runs with sensible
# defaults (demo connectors, console/file notifications, localhost-only web
# binding) if none of these are set.

# --- AI provider (optional) ---------------------------------------------
OPENAI_API_KEY=
# Ollama AI provider (local, optional alternative to OpenAI)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# --- Production data connector (optional) -------------------------------
# RentCast (https://www.rentcast.io/) — a real REST API with a free tier.
RENTCAST_API_KEY=

# --- Web dashboard (all optional; see docs/32_Web_Dashboard.md) ---------
WEB_HOST=127.0.0.1
WEB_PORT=5000
WEB_DEBUG=0
# Set to 1 to bind beyond localhost — the one explicit opt-in required to
# expose the app on the network. Leave unset/0 for local-only use.
WEB_ALLOW_NETWORK=0
# Auto-generated and persisted to data/.web_secret_key if left unset. Set this
# explicitly in production — see docs/45_Deployment_Guide.md.
WEB_SECRET_KEY=

# --- Production deployment only (all optional; see docs/45_Deployment_Guide.md) ---
# Set to 1 only once a reverse proxy/PaaS edge terminates HTTPS in front of
# this app — enables the Secure cookie flag and trusts one hop of
# X-Forwarded-* headers. Leave unset/0 for local HTTP development.
WEB_SECURE_COOKIES=0
WEB_TRUST_PROXY=0
# Several hosting platforms (Render, Railway, Heroku) inject PORT
# automatically; WEB_PORT above always takes precedence if also set.
PORT=
# Redirects data/ and output/ to a mounted persistent volume instead of a
# path under the application code — required on any host with an ephemeral
# container filesystem. Leave unset for local development.
RENTAL_AGENT_DATA_DIR=
RENTAL_AGENT_OUTPUT_DIR=

# --- Notification channels (all optional; see docs/31_Notification_Delivery.md) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SENDER=
SMTP_RECIPIENT=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT=10

WEBHOOK_URL=
WEBHOOK_SIGNING_SECRET=
